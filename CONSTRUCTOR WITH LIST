class CIRCLE:
    def __init__(self):
        x=int (input("ENTER RADIUS : "))
        self.radius=x
        
    def display(self):
        print("AREA OF CIRCLE:",3.14*self.radius**2)
a=int(input("ENTER NUMBER OF CIRCLES:"))
circle=[]
for i in range(a):
    c=CIRCLE()
    circle.append(c)
    c.display()
    print("_____________________")
